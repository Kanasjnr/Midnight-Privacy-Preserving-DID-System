pragma language_version >= 0.20 && <= 0.21;

include 'types';

export ledger schema_registry_root: Bytes<32>;

export circuit registerSchema(
  schema_id: Bytes<32>,
  creator_pk_hash: Bytes<32>,
  schema_json_hash: Bytes<32>
): [] {
  const schema_hash = persistentHash<Vector<3, Bytes<32>>>([
    schema_id,
    creator_pk_hash,
    schema_json_hash
  ]);

  schema_registry_root = disclose(persistentHash<Vector<2, Bytes<32>>>([
    schema_registry_root,
    schema_hash
  ]));
}
